<Project>
  <PropertyGroup>
    <RestorePackagesPath>$(MSBuildThisFileDirectory)/packages</RestorePackagesPath>
  </PropertyGroup>

  <!-- Platform-specific build configurations -->
  <Import Project="$(MSBuildThisFileDirectory)/android/build-configs.props"
          Condition="Exists('$(MSBuildThisFileDirectory)/android/build-configs.props')" />
</Project>